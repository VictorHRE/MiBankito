<Window x:Class="MiBankito.Home"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Dashboard de Mi Bankito" Height="800" Width="1500"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Light" PrimaryColor="DeepOrange" SecondaryColor="LightBlue" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign2.Defaults.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MiBankito;component/Colors.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Estilo para los botones de navegación del header -->
            <Style x:Key="HeaderNavButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
                <Setter Property="Margin" Value="0,0,8,0"/>
                <Setter Property="Foreground" Value="{StaticResource PrimaryIndigoBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource PrimaryIndigoBrush}"/>
                <Style.Triggers>
                    <Trigger Property="Tag" Value="Active">
                        <Setter Property="Background" Value="{StaticResource PrimaryIndigoBrush}"/>
                        <Setter Property="Foreground" Value="{StaticResource TextWhiteBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Estilo para las tarjetas de servicios -->
            <Style x:Key="ServiceCardStyle" TargetType="materialDesign:Card">
                <Setter Property="Width" Value="240"/>
                <Setter Property="Height" Value="220"/>
                <Setter Property="Margin" Value="8"/>
                <Setter Property="Padding" Value="8"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Background" Value="{StaticResource BackgroundWhiteBrush}"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="#000000" BlurRadius="6" ShadowDepth="1" Opacity="0.1"/>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect Color="Black" BlurRadius="12" ShadowDepth="2" Opacity="0.3"/>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Estilo para los botones de ordenamiento -->
            <Style x:Key="SortButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignIconButton}">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource PrimaryIndigoBrush}"/>
                <Setter Property="BorderBrush" Value="#DDE2E6"/>
                <Setter Property="BorderThickness" Value="2"/>
                <Setter Property="Width" Value="40"/>
                <Setter Property="Height" Value="40"/>
                <Style.Triggers>
                    <Trigger Property="Tag" Value="Active">
                        <Setter Property="Background" Value="{StaticResource PrimaryIndigoBrush}"/>
                        <Setter Property="Foreground" Value="{StaticResource TextWhiteBrush}"/>
                        <Setter Property="BorderBrush" Value="{StaticResource PrimaryIndigoBrush}"/>
                    </Trigger>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource PrimaryIndigoBrush}"/>
                        <Setter Property="Foreground" Value="{StaticResource TextWhiteBrush}"/>
                        <Setter Property="Opacity" Value="0.8"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="8" Background="{StaticResource BackgroundPrimaryBrush}" BorderBrush="#DDE2E6" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="72"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header Superior -->
            <Border x:Name="HeaderBorder" Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                <Grid Margin="25,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Logo y Botones de Navegación -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="/MiBankito;component/MiBankito/resources/miBankito.png" Width="350" Height="300" Margin="-15,0,30,-15" VerticalAlignment="Center"/>
                        <Button x:Name="BancosBtn" Content="Bancos" Style="{StaticResource HeaderNavButtonStyle}" Click="NavButton_Click"  Tag="Active" Width="150" Height="50" FontSize="20"/>
                        <Button x:Name="RemesasBtn" Content="Remesas" Style="{StaticResource HeaderNavButtonStyle}" Click="NavButton_Click" Width="150" Height="50" FontSize="20"/>
                        <Button x:Name="ServiciosBtn" Content="Servicios Básicos" Style="{StaticResource HeaderNavButtonStyle}" Click="NavButton_Click" Width="200" Height="50" FontSize="20"/>
                        <Button x:Name="ReporteBtn" Content="Reporte" Style="{StaticResource HeaderNavButtonStyle}" Click="ReporteCard_Click"  Width="150" Height="50" FontSize="20"/>
                    </StackPanel>

                    <!-- Botón Sol. Whatsapp y botón de cerrar -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="WhatsAppBtn" Click="WhatsAppBtn_Click" Width="240" Height="50" Margin="0,0,12,0" Background="#25D366" Foreground="White" BorderBrush="#25D366">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="Whatsapp" Width="40" Height="40" Margin="0,0,8,0" Foreground="White"/>
                                <TextBlock Text="Solicitudes WhatsApp" FontSize="16" VerticalAlignment="Center" Foreground="White"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource MaterialDesignIconButton}" ToolTip="Cerrar aplicación" Click="CloseWindow_Click">
                            <materialDesign:PackIcon Kind="Close" Width="20" Height="20"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Contenido Principal (Vistas) -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid>
                    <ContentControl x:Name="MainContent" Visibility="Collapsed" Margin="16"/>

                    <StackPanel x:Name="ServicesView" Margin="16">

                        <!-- Buscador -->
                        <Border Background="{StaticResource BackgroundWhiteBrush}" Padding="24,12" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="SearchTextBox"
                                         Grid.Column="0"
                                         materialDesign:HintAssist.Hint="Buscar servicio por nombre..."
                                         materialDesign:TextFieldAssist.HasClearButton="True"
                                         TextChanged="SearchTextBox_TextChanged"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Padding="12,8"
                                         FontSize="16"/>
                                <Button x:Name="SortAscendingButton"
                                        Grid.Column="1"
                                        Style="{StaticResource SortButtonStyle}"
                                        ToolTip="Ordenar ascendente"
                                        Click="SortAscendingButton_Click"
                                        Margin="8,0,4,0">
                                    <materialDesign:PackIcon Kind="ArrowUp" Width="20" Height="20"/>
                                </Button>
                                <Button x:Name="SortDescendingButton"
                                        Grid.Column="2"
                                        Style="{StaticResource SortButtonStyle}"
                                        ToolTip="Ordenar descendente"
                                        Click="SortDescendingButton_Click"
                                        Margin="4,0,0,0">
                                    <materialDesign:PackIcon Kind="ArrowDown" Width="20" Height="20"/>
                                </Button>
                            </Grid>
                        </Border>

                        <WrapPanel x:Name="ServicesPanel" HorizontalAlignment="Center" MaxWidth="1280"/>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
