<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Colores principales de la aplicación -->
    
    <!-- Colores de fondo -->
	<SolidColorBrush x:Key="BackgroundPrimaryBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BackgroundSecondaryBrush" Color="#FAFAFA"/>
    <SolidColorBrush x:Key="BackgroundTertiaryBrush" Color="#F8F9FA"/>
    <SolidColorBrush x:Key="BackgroundWhiteBrush" Color="White"/>
    <SolidColorBrush x:Key="BackgroundBlackBrush" Color="Black"/>
    <!-- Colores primarios -->
    <SolidColorBrush x:Key="PrimaryBlueBrush" Color="#1976D2"/>
    <SolidColorBrush x:Key="PrimaryDarkBlueBrush" Color="#172f4f"/>
    <SolidColorBrush x:Key="PrimaryIndigoBrush" Color="#3F51B5"/>
    <SolidColorBrush x:Key="PrimaryDeepOrangeBrush" Color="#e6630c"/>
    
    <!-- Colores secundarios -->
    <SolidColorBrush x:Key="SecondaryLightBlueBrush" Color="#E3F2FD"/>
    <SolidColorBrush x:Key="SecondaryPinkBrush" Color="#E91E63"/>
    <SolidColorBrush x:Key="SecondaryGreenBrush" Color="#4CAF50"/>
    <SolidColorBrush x:Key="SecondaryOrangeBrush" Color="#FF9800"/>
    
    <!-- Colores de texto -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#424242"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#757575"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#9E9E9E"/>
    <SolidColorBrush x:Key="TextLightBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="TextWhiteBrush" Color="White"/>
    
    <!-- Colores de estado -->
    <SolidColorBrush x:Key="SuccessGreenBrush" Color="#4CAF50"/>
    <SolidColorBrush x:Key="SuccessDarkGreenBrush" Color="#2E7D32"/>
    <SolidColorBrush x:Key="SuccessLightGreenBrush" Color="#E8F5E8"/>
    <SolidColorBrush x:Key="ErrorRedBrush" Color="#F44336"/>
    <SolidColorBrush x:Key="WarningOrangeBrush" Color="#FF9800"/>
    <SolidColorBrush x:Key="InfoBlueBrush" Color="#2196F3"/>
    
    <!-- Colores de sombra -->
    <SolidColorBrush x:Key="ShadowColorBrush" Color="#172f4f"/>
    
    <!-- Colores de borde y separadores -->
    <SolidColorBrush x:Key="BorderLightBrush" Color="#BDBDBD"/>
    <SolidColorBrush x:Key="BorderMediumBrush" Color="#9E9E9E"/>
    
    <!-- Colores de hover y estados interactivos -->
    <SolidColorBrush x:Key="HoverIndigoBrush" Color="#E8EAF6"/>
    <SolidColorBrush x:Key="HoverDarkIndigoBrush" Color="#C5CAE9"/>
    <SolidColorBrush x:Key="PressedIndigoBrush" Color="#303F9F"/>
    
    <!-- Colores específicos de la aplicación -->
    <SolidColorBrush x:Key="MenuBackgroundBrush" Color="#172f4f"/>
    <SolidColorBrush x:Key="MenuTextBrush" Color="#E3F2FD"/>
    <SolidColorBrush x:Key="MenuTextSecondaryBrush" Color="#90A4AE"/>
    
    <!-- Colores de exportación -->
    <SolidColorBrush x:Key="ExportGreenBrush" Color="#27AE60"/>
    
    <!-- Colores de cambio y total -->
    <SolidColorBrush x:Key="ChangeBackgroundBrush" Color="#E8F5E8"/>
    <SolidColorBrush x:Key="ChangeTextBrush" Color="#4CAF50"/>
    <SolidColorBrush x:Key="ChangeDarkTextBrush" Color="#2E7D32"/>
    <SolidColorBrush x:Key="TotalBackgroundBrush" Color="#E3F2FD"/>
    <SolidColorBrush x:Key="TotalTextBrush" Color="#1976D2"/>
    <SolidColorBrush x:Key="TotalDarkTextBrush" Color="#1565C0"/>

    <!-- Alias y brushes faltantes para compatibilidad y centralización -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#1976D2"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#3F51B5"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#e6630c"/>
    <SolidColorBrush x:Key="BackgroundDisabledBrush" Color="#ECEFF1"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#4CAF50"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#F44336"/>

    <!-- Elevation shadows para MaterialDesign -->
    <DropShadowEffect x:Key="MaterialDesignElevationShadow1" BlurRadius="5" ShadowDepth="2" Color="#22000000"/>
    <DropShadowEffect x:Key="MaterialDesignElevationShadow2" BlurRadius="10" ShadowDepth="4" Color="#22000000"/>

</ResourceDictionary>